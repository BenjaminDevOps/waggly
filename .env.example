# ========================================
# 🐾 Waggly - Environment Configuration
# ========================================
#
# This is a template file. To use it:
# 1. Copy this file and rename it to: .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control (it's in .gitignore)
#
# ========================================

# ========================================
# 🤖 Google Gemini AI Configuration
# ========================================
#
# Get your API key from: https://aistudio.google.com/apikey
#
# Model used: gemini-3-flash-preview (Latest Generation)
# - Fastest response times (<1 second)
# - Best medical reasoning
# - Superior image analysis
# - Cost: ~$0.43 per 1000 diagnoses
#
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ========================================
# 🔥 Firebase Configuration (Optional)
# ========================================
#
# Firebase is configured via google-services.json (Android)
# and GoogleService-Info.plist (iOS).
#
# These files are NOT committed to git for security.
# Download them from: https://console.firebase.google.com/
#
# No additional env vars needed for Firebase.
#

# ========================================
# 🌐 API Endpoints (Optional)
# ========================================
#
# Uncomment and configure if you have custom backend endpoints
#
# API_BASE_URL=https://api.waggly.com
# API_TIMEOUT_SECONDS=30
# API_VERSION=v1

# ========================================
# 🔐 Feature Flags (Optional)
# ========================================
#
# Enable/disable features for testing
#
# ENABLE_ANALYTICS=true
# ENABLE_CRASH_REPORTING=true
# ENABLE_DEBUG_MODE=false
# ENABLE_OFFLINE_MODE=true

# ========================================
# 💰 In-App Purchase Configuration (Optional)
# ========================================
#
# Configure your premium plan SKUs
#
# PREMIUM_MONTHLY_SKU=waggly_premium_monthly
# PREMIUM_YEARLY_SKU=waggly_premium_yearly

# ========================================
# 📊 Analytics & Tracking (Optional)
# ========================================
#
# MIXPANEL_TOKEN=YOUR_MIXPANEL_TOKEN
# AMPLITUDE_API_KEY=YOUR_AMPLITUDE_KEY
# SENTRY_DSN=YOUR_SENTRY_DSN

# ========================================
# 🔧 Development Settings
# ========================================
#
# APP_ENV=development  # development | staging | production
# LOG_LEVEL=debug      # debug | info | warning | error
